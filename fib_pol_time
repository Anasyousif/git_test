def fib(n, memo=None):
    # Initialize the memo dictionary on the first call
    if memo is None:
        memo = {}
        
    # Check if we've already calculated this value
    if n in memo:
        return memo[n]
    
    # Base cases
    if n == 0:
        return 0
    if n == 1:
        return 1
    
    # Calculate, store in memo, and return
    memo[n] = fib(n - 1, memo) + fib(n - 2, memo)
    return memo[n]